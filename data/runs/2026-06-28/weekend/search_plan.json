      "hedge fund positioning",
      "credit markets outlook"
    ],
    "secondary_topics": [
      "currency markets outlook",
      "oil gold commodities outlook",
      "AI semiconductor outlook",
      "consumer stocks outlook",
      "bank stocks outlook"
    ],
    "exclusion_terms": [
      "racism",
      "sexism",
      "discrimination",
      "diversity initiative",
      "DEI",
      "climate protest",
      "social justice",
      "inequality",
      "activist investor ESG",
